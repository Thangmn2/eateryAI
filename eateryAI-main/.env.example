# Copy this file to .env.local and fill in your local values.
# Do not commit .env.local or any real secrets.

# Azure AI Vision endpoint, for example:
# https://your-resource-name.cognitiveservices.azure.com/
AZURE_VISION_ENDPOINT=

# Azure AI Vision key used only by the Node OCR proxy.
AZURE_VISION_KEY=

# Optional Firecrawl API key for refreshing the Chipotle builder snapshot
# against the live nutrition calculator page.
FIRECRAWL_API_KEY=

# Optional override when self-hosting Firecrawl.
FIRECRAWL_BASE_URL=https://api.firecrawl.dev

# Local OCR proxy port.
PORT=8787

# Optional polling controls for the async Read API.
OCR_POLL_INTERVAL_MS=1500
OCR_MAX_ATTEMPTS=12

# MongoDB connection (used for Menufy data + restaurants).
MONGODB_URI=mongodb+srv://thangmn2_db_user:ctZhHx8L4doMt9UI@eateryscrapecluster.ky3zlsc.mongodb.net/?appName=EateryScrapeCluster
MONGODB_DB=scraped_restaurants
